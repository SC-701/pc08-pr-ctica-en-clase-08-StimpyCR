@page
@model Web.Pages.Productos.EditarModel
@{
    ViewData["Title"] = "Editar Producto";
}

<header class="subhead">
    <div class="container">
        <div class="masthead-subheading">SC-701: Programación Web Avanzada</div>
        <div class="masthead-heading text-uppercase">Ejercicio producto</div>
    </div>
</header>

<section class="page-section bg-light" id="principal">
    <div class="container">
        <div class="text-center">
            <h2 class="section-heading text-uppercase">Editar producto</h2>
            <h3 class="section-subheading text-muted">Modifique los datos del producto</h3>
        </div>

        <div class="col-xl-5 col-lg-6 col-md-8 col-sm-10 mx-auto ">
            <form method="post">

                <div class="form-group">
                    <label class="control-label" asp-for="Producto.Nombre"></label>
                    <input class="form-control" asp-for="Producto.Nombre" />
                    <span class="text-danger" asp-validation-for="Producto.Nombre"></span>
                </div>

                <div class="form-group">
                    <label class="control-label" asp-for="Producto.Descripcion"></label>
                    <textarea class="form-control" asp-for="Producto.Descripcion" rows="3"></textarea>
                    <span class="text-danger" asp-validation-for="Producto.Descripcion"></span>
                </div>

                <div class="form-group">
                    <label class="control-label" asp-for="Producto.Precio"></label>
                    <input class="form-control" type="number" step="0.01" asp-for="Producto.Precio" />
                    <span class="text-danger" asp-validation-for="Producto.Precio"></span>
                </div>

                <div class="form-group">
                    <label class="control-label" asp-for="Producto.Stock"></label>
                    <input class="form-control" type="number" asp-for="Producto.Stock" />
                    <span class="text-danger" asp-validation-for="Producto.Stock"></span>
                </div>

                <div class="form-group">
                    <label class="control-label" asp-for="Producto.CodigoBarras"></label>
                    <input class="form-control" asp-for="Producto.CodigoBarras" />
                    <span class="text-danger" asp-validation-for="Producto.CodigoBarras"></span>
                </div>

                <div class="form-group">
                    <label for="categorias">Categoría</label>
                    <select class="form-select" id="categorias" asp-items="Model.categorias" onchange="fetchSubCategorias()">
                        <option value="">Seleccione una categoría</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="control-label" asp-for="subCategoriaSeleccionada"></label>
                    <select asp-for="subCategoriaSeleccionada" class="form-select" asp-items="Model.subCategorias" id="subCategorias">
                        <option value="">Seleccione una subcategoría</option>
                    </select>
                    <span class="text-danger" asp-validation-for="subCategoriaSeleccionada"></span>
                </div>

                <div class="text-danger" asp-validation-summary="All"></div>

                <div class="form-group">
                    <a class="btn btn-primary" asp-page="./Index">Regresar</a>
                    <input type="submit" value="Editar" class="btn btn-warning" />
                </div>

                <input type="hidden" asp-for="Producto.Id" />
                <input type="hidden" asp-for="categoriaSeleccionada" />
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        async function fetchSubCategorias() {
            const categoriaId = document.getElementById('categorias').value;
            if (!categoriaId) {
                return;
            }
            try {
                const response = await fetch(`?handler=ObtenerSubCategorias&categoriaId=${categoriaId}`);
                if (!response.ok) {
                    throw new Error('Error obteniendo los datos');
                }
                const subCategorias = await response.json();
                const subCategoriasSelect = document.getElementById('subCategorias');
                subCategoriasSelect.innerHTML = '<option value="">Seleccione una subcategoría</option>';
                subCategorias.forEach(subCategoria => {
                    const option = document.createElement('option');
                    option.value = subCategoria.id;
                    option.text = subCategoria.nombre;
                    subCategoriasSelect.appendChild(option);
                });
            } catch (error) {
                console.error('Error obteniendo los datos:', error);
            }
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}